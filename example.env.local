# Copiază în `.env` sau `.env.local` (nu se comite). Secretul trebuie să fie identic cu
# `REPORT_SERVICE_SECRET` din `report-service/.env` (sau Railway/Render).
# Local: URL de mai jos. Pe Vercel: REPORT_SERVICE_URL=https://… (URL public report-service).

REPORT_SERVICE_URL=http://127.0.0.1:4000
REPORT_SERVICE_SECRET=înlocuiește-cu-același-secret-ca-report-service
