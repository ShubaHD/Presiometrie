# Copiază în .env și completează valorile (fișierul .env nu se comite).
PORT=4000
REPORT_SERVICE_SECRET=
# Fără spații la început/sfârșit; exact „Project URL” din Supabase → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REPORTS_BUCKET=reports
# După deploy Vercel: https://proiectul-tau.vercel.app (fără / la final)
REPORT_SERVICE_CORS_ORIGIN=
# Opțional; gol = folderul templates din report-service
TEMPLATES_DIR=
