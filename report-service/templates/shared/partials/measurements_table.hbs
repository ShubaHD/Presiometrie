<section class="section">
  <h2>{{#if i18n.h2_measurements}}{{i18n.h2_measurements}}{{else}}Măsurători{{/if}}</h2>
  <table class="data">
    <thead>
      <tr>
        <th>{{#if i18n.th_indicator}}{{i18n.th_indicator}}{{else}}Indicator{{/if}}</th>
        <th>{{#if i18n.th_value}}{{i18n.th_value}}{{else}}Valoare{{/if}}</th>
        <th>{{#if i18n.th_unit}}{{i18n.th_unit}}{{else}}Unitate{{/if}}</th>
      </tr>
    </thead>
    <tbody>
      {{#each measurements}}
        <tr><td>{{label}}</td><td>{{value}}</td><td>{{unit}}</td></tr>
      {{else}}
        <tr><td colspan="3">—</td></tr>
      {{/each}}
    </tbody>
  </table>
</section>
