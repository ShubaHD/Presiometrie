{{#if show.iso17892Section}}
<section class="section">
  <h2>Raportare obligatorie (SR EN ISO 17892-7:2018 §8.1)</h2>
  <table class="data">
    <thead>
      <tr><th>Cerință</th><th>Conținut raport</th></tr>
    </thead>
    <tbody>
      {{#each iso17892MandatoryRows}}
        <tr><td>{{label}}</td><td>{{value}}</td></tr>
      {{else}}
        <tr><td colspan="2">—</td></tr>
      {{/each}}
    </tbody>
  </table>
  <p class="muted">
    Notă: câmpurile marcate cu „—” trebuie completate în aplicație (metadate raport / măsurători).
  </p>
</section>
{{/if}}

